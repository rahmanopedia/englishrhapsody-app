rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı: Sadece kendi verisi ────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Yardımcı: Admin kontrolü (custom claims) ─────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Yardımcı: client _updatedAt ile rate limit ────────────
    function rateLimitMs(minMs) {
      return resource == null
          || !('_updatedAt' in resource.data)
          || request.time.toMillis() - resource.data._updatedAt > minMs;
    }

    // ── Yardımcı: server timestamp ile rate limit ─────────────
    function rateLimitServer(dur) {
      return resource == null
          || !('updatedAt' in resource.data)
          || request.time > resource.data.updatedAt + dur;
    }

    // ── Kullanıcı profil meta verisi ──────────────────────────
    match /users/{userId}/meta/profile {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && request.resource.data.keys().hasAll(['email'])
                   && request.resource.data.keys().size() <= 10
                   && request.resource.data.email is string
                   && request.resource.data.email.size() <= 300
                   && (!('name' in request.resource.data) || request.resource.data.name.size() <= 100);
    }

    // ── Kullanıcı öğrenim durumu (state) ──────────────────────
    match /users/{userId}/data/state {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && request.resource.data.keys().size() <= 80
                   && rateLimitMs(2000)
                   && (!('xp' in request.resource.data) || (
                        request.resource.data.xp is number
                        && request.resource.data.xp >= 0
                        && request.resource.data.xp <= 9999999
                        && (resource == null
                            || !('xp' in resource.data)
                            || request.resource.data.xp - resource.data.xp <= 5000)
                   ))
                   && (!('level' in request.resource.data) || (
                        request.resource.data.level is number
                        && request.resource.data.level >= 0
                        && request.resource.data.level <= 9999
                   ))
                   && (!('streak' in request.resource.data) || (
                        request.resource.data.streak is number
                        && request.resource.data.streak >= 0
                        && request.resource.data.streak <= 3650
                   ))
                   && (!('sessions' in request.resource.data) || (
                        request.resource.data.sessions is number
                        && request.resource.data.sessions >= 0
                        && request.resource.data.sessions <= 999999
                   ));
    }

    // ── Diğer kullanıcı alt koleksiyonları ────────────────────
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // ── Liderlik Tablosu ──────────────────────────────────────
    match /leaderboards/{period}/users/{userId} {
      allow read: if request.auth != null;

      allow create: if isOwner(userId)
                    && rateLimitServer(duration.value(5, 'm'))
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid    is string && request.resource.data.uid == userId
                    && request.resource.data.xp     is number && request.resource.data.xp    >= 0 && request.resource.data.xp    <= 9999999
                    && request.resource.data.level  is number && request.resource.data.level  >= 1 && request.resource.data.level  <= 9999
                    && request.resource.data.name   is string && request.resource.data.name.size()   <= 100
                    && request.resource.data.avatar is string && request.resource.data.avatar.size() <= 5
                    && (!('cefrLevel' in request.resource.data) || (
                         request.resource.data.cefrLevel is string
                         && request.resource.data.cefrLevel.size() <= 5));

      allow update: if isOwner(userId)
                    && rateLimitServer(duration.value(5, 'm'))
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid    is string && request.resource.data.uid == userId
                    && request.resource.data.xp     is number && request.resource.data.xp    >= 0 && request.resource.data.xp    <= 9999999
                    && request.resource.data.level  is number && request.resource.data.level  >= 1 && request.resource.data.level  <= 9999
                    && request.resource.data.name   is string && request.resource.data.name.size()   <= 100
                    && request.resource.data.avatar is string && request.resource.data.avatar.size() <= 5
                    && (!('cefrLevel' in request.resource.data) || (
                         request.resource.data.cefrLevel is string
                         && request.resource.data.cefrLevel.size() <= 5));

      allow delete: if isOwner(userId);
    }

    // ── Güvenlik Olayları ────────────────────────────────────
    match /security_events/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.type is string
                    && request.resource.data.type.size() <= 50;
      // Custom claims ile admin kontrolü (hardcoded email yerine)
      allow read: if isAdmin();
      allow update, delete: if false;
    }


    // ── Rival Liderlik Tablosu ───────────────────────────────
    match /rival_leaderboard/{period}/users/{userId} {
      allow read: if request.auth != null;

      allow create: if isOwner(userId)
                    && rateLimitServer(duration.value(2, 'm'))
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid     is string && request.resource.data.uid == userId
                    && request.resource.data.name    is string && request.resource.data.name.size()   <= 100
                    && request.resource.data.avatar  is string && request.resource.data.avatar.size() <= 5
                    && request.resource.data.wins    is number && request.resource.data.wins    >= 0 && request.resource.data.wins    <= 99999
                    && request.resource.data.losses  is number && request.resource.data.losses  >= 0 && request.resource.data.losses  <= 99999
                    && request.resource.data.ties    is number && request.resource.data.ties    >= 0 && request.resource.data.ties    <= 99999
                    && request.resource.data.winRate is number && request.resource.data.winRate >= 0 && request.resource.data.winRate <= 100;

      allow update: if isOwner(userId)
                    && rateLimitServer(duration.value(2, 'm'))
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid     is string && request.resource.data.uid == userId
                    && request.resource.data.name    is string && request.resource.data.name.size()   <= 100
                    && request.resource.data.avatar  is string && request.resource.data.avatar.size() <= 5
                    && request.resource.data.wins    is number && request.resource.data.wins    >= 0 && request.resource.data.wins    <= 99999
                    && request.resource.data.losses  is number && request.resource.data.losses  >= 0 && request.resource.data.losses  <= 99999
                    && request.resource.data.ties    is number && request.resource.data.ties    >= 0 && request.resource.data.ties    <= 99999
                    && request.resource.data.winRate is number && request.resource.data.winRate >= 0 && request.resource.data.winRate <= 100;

      allow delete: if isOwner(userId);
    }

    // ── Rival: Eşleşme kuyruğu ───────────────────────────────
    match /rival_queue/{uid} {
      allow read: if request.auth != null;
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.mode is string
                    && request.resource.data.mode.size() <= 20
                    && request.resource.data.mode_level is string
                    && request.resource.data.mode_level.size() <= 30;
      // Kendi güncellemesi VEYA herhangi auth kullanıcı sadece matchId ekleyebilir (rate limited)
      allow update: if isOwner(uid)
                    || (request.auth != null
                        && rateLimitServer(duration.value(10, 's'))
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['matchId'])
                        && request.resource.data.matchId is string
                        && request.resource.data.matchId.size() <= 64);
      allow delete: if request.auth != null;
    }

    // ── Rival: Maç belgeleri ──────────────────────────────────
    match /rival_matches/{matchId} {
      allow read: if request.auth != null
                  && (resource == null
                      || resource.data.hostId == request.auth.uid
                      || resource.data.guestId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && request.resource.data.questions is list
                    && request.resource.data.questions.size() <= 20;
      allow update: if request.auth != null
                    && (resource.data.hostId == request.auth.uid
                        || resource.data.guestId == request.auth.uid)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['hostScore','guestScore','hostQ','guestQ',
                                   'hostClip','guestClip','hostDone','guestDone',
                                   'guestId','guestName','status'])
                    && (!('hostScore'  in request.resource.data) || (request.resource.data.hostScore  is number && request.resource.data.hostScore  >= 0 && request.resource.data.hostScore  <= 10000))
                    && (!('guestScore' in request.resource.data) || (request.resource.data.guestScore is number && request.resource.data.guestScore >= 0 && request.resource.data.guestScore <= 10000))
                    && (!('hostQ'      in request.resource.data) || (request.resource.data.hostQ      is number && request.resource.data.hostQ      >= 0 && request.resource.data.hostQ      <= 50))
                    && (!('guestQ'     in request.resource.data) || (request.resource.data.guestQ     is number && request.resource.data.guestQ     >= 0 && request.resource.data.guestQ     <= 50))
                    && (!('hostClip'   in request.resource.data) || (request.resource.data.hostClip   is number && request.resource.data.hostClip   >= 0 && request.resource.data.hostClip   <= 10))
                    && (!('guestClip'  in request.resource.data) || (request.resource.data.guestClip  is number && request.resource.data.guestClip  >= 0 && request.resource.data.guestClip  <= 10))
                    && (!('hostDone'   in request.resource.data) || request.resource.data.hostDone  is bool)
                    && (!('guestDone'  in request.resource.data) || request.resource.data.guestDone is bool);
      allow delete: if false;
    }

    // ── Reddet: Yukarıdaki kurallara uymayan her şey ──────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
