rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Kullanıcı profil meta verisi ──────────────────────────
    match /users/{userId}/meta/profile {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().hasAll(['email'])
                   && request.resource.data.keys().size() <= 10;
    }

    // ── Kullanıcı öğrenim durumu (state) ─────────────────────
    // Sadece kendi verisini okuyup yazabilir; alan sayısı ile kötüye kullanım önlenir
    match /users/{userId}/data/state {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 80;
    }

    // ── Diğer kullanıcı alt koleksiyonları ───────────────────
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Liderlik Tablosu ──────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece kendi satırını yazabilir
    match /leaderboards/{period}/users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 10;
    }

    // ── Reddet: Yukarıdaki kurallara uymayan her şey ─────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
