rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Kullanıcı profil meta verisi ──────────────────────────
    match /users/{userId}/meta/profile {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().hasAll(['email'])
                   && request.resource.data.keys().size() <= 10;
    }

    // ── Kullanıcı öğrenim durumu (state) ─────────────────────
    // Sadece kendi verisini okuyup yazabilir; alan sayısı ile kötüye kullanım önlenir
    match /users/{userId}/data/state {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 80
                   // XP ve level alanı varsa makul sınırlar içinde olmalı
                   && (!('xp'    in request.resource.data) || (request.resource.data.xp    is number && request.resource.data.xp    >= 0 && request.resource.data.xp    <= 9999999))
                   && (!('level' in request.resource.data) || (request.resource.data.level is number && request.resource.data.level >= 0 && request.resource.data.level <= 9999));
    }

    // ── Diğer kullanıcı alt koleksiyonları ───────────────────
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Liderlik Tablosu ──────────────────────────────────────
    // Giriş yapmış herkes okuyabilir; sadece kendi satırını yazabilir/silebilir
    // Rate limit: ilk yazma serbest; güncelleme en az 5 dakikada bir
    match /leaderboards/{period}/users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 10
                   && request.resource.data.xp    is number && request.resource.data.xp    >= 0 && request.resource.data.xp    <= 50000
                   && request.resource.data.level  is number && request.resource.data.level >= 1 && request.resource.data.level <= 500
                   && request.resource.data.name   is string && request.resource.data.name.size() <= 100;

      allow update: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 10
                   && request.resource.data.xp    is number && request.resource.data.xp    >= 0 && request.resource.data.xp    <= 50000
                   && request.resource.data.level  is number && request.resource.data.level >= 1 && request.resource.data.level <= 500
                   && request.resource.data.name   is string && request.resource.data.name.size() <= 100
                   // Rate limit: son güncellemeden en az 5 dakika geçmiş olmalı
                   && (
                     !('updatedAt' in resource.data) ||
                     request.time > resource.data.updatedAt + duration.value(300, 's')
                   );

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Reddet: Yukarıdaki kurallara uymayan her şey ─────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
