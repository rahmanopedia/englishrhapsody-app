rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı: Sadece kendi verisi ────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Yardımcı: client _updatedAt ile rate limit ────────────
    // minMs milisaniye geçmeden aynı dokümanı tekrar yazdırtma
    function rateLimitMs(minMs) {
      return resource == null
          || !('_updatedAt' in resource.data)
          || request.time.toMillis() - resource.data._updatedAt > minMs;
    }

    // ── Yardımcı: server timestamp ile rate limit ─────────────
    function rateLimitServer(dur) {
      return resource == null
          || !('updatedAt' in resource.data)
          || request.time > resource.data.updatedAt + dur;
    }

    // ── Kullanıcı profil meta verisi ──────────────────────────
    match /users/{userId}/meta/profile {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && request.resource.data.keys().hasAll(['email'])
                   && request.resource.data.keys().size() <= 10
                   && request.resource.data.email is string
                   && request.resource.data.email.size() <= 300
                   && (!('name' in request.resource.data) || request.resource.data.name.size() <= 100);
    }

    // ── Kullanıcı öğrenim durumu (state) ──────────────────────
    match /users/{userId}/data/state {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   // Alan sayısı sınırı
                   && request.resource.data.keys().size() <= 80
                   // Rate limit: 2 saniyede en fazla 1 yazma (bot engeli)
                   && rateLimitMs(2000)
                   // XP: 0-9999999 arası, tek yazımda max 5000 artış
                   && (!('xp' in request.resource.data) || (
                        request.resource.data.xp is number
                        && request.resource.data.xp >= 0
                        && request.resource.data.xp <= 9999999
                        && (resource == null
                            || !('xp' in resource.data)
                            || request.resource.data.xp - resource.data.xp <= 5000)
                   ))
                   // Level: 0-9999
                   && (!('level' in request.resource.data) || (
                        request.resource.data.level is number
                        && request.resource.data.level >= 0
                        && request.resource.data.level <= 9999
                   ))
                   // Streak: 0-3650 (10 yıl)
                   && (!('streak' in request.resource.data) || (
                        request.resource.data.streak is number
                        && request.resource.data.streak >= 0
                        && request.resource.data.streak <= 3650
                   ))
                   // Sessions: 0-999999
                   && (!('sessions' in request.resource.data) || (
                        request.resource.data.sessions is number
                        && request.resource.data.sessions >= 0
                        && request.resource.data.sessions <= 999999
                   ));
    }

    // ── Diğer kullanıcı alt koleksiyonları ────────────────────
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // ── Liderlik Tablosu ──────────────────────────────────────
    match /leaderboards/{period}/users/{userId} {
      allow read: if request.auth != null;

      allow create: if isOwner(userId)
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid   is string  && request.resource.data.uid == userId
                    && request.resource.data.xp    is number  && request.resource.data.xp    >= 0  && request.resource.data.xp    <= 9999999
                    && request.resource.data.level  is number  && request.resource.data.level  >= 1  && request.resource.data.level  <= 9999
                    && request.resource.data.name   is string  && request.resource.data.name.size()  <= 100
                    && request.resource.data.avatar is string  && request.resource.data.avatar.size() <= 5;

      // Rate limit: server timestamp ile 5 dakikada bir güncelleme
      allow update: if isOwner(userId)
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.uid   is string  && request.resource.data.uid == userId
                    && request.resource.data.xp    is number  && request.resource.data.xp    >= 0  && request.resource.data.xp    <= 9999999
                    && request.resource.data.level  is number  && request.resource.data.level  >= 1  && request.resource.data.level  <= 9999
                    && request.resource.data.name   is string  && request.resource.data.name.size()  <= 100
                    && request.resource.data.avatar is string  && request.resource.data.avatar.size() <= 5
                    && rateLimitServer(duration.value(5, 'm'));

      allow delete: if isOwner(userId);
    }

    // ── Arkadaş Kodları ───────────────────────────────────────
    // Herkes okuyabilir (arkadaş arama), yalnızca sahibi yazabilir
    match /friendCodes/{code} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.resource.data.keys().hasAll(['uid'])
                            && request.resource.data.keys().size() <= 3
                            && request.resource.data.uid is string
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // ── Meydan Okumalar (gelen bildirimler) ──────────────────
    // Herhangi bir oturum açmış kullanıcı başkasına meydan okuma gönderebilir
    match /users/{userId}/challenges/{challengeId} {
      // Sahibi okuyabilir / silebilir
      allow read, delete: if isOwner(userId);
      // Gönderen kendi uid'iyle eşleşen challenge yazabilir (challengeId == kendi uid)
      allow create: if request.auth != null
                    && request.auth.uid == challengeId
                    && request.resource.data.keys().hasAll(['fromUid','fromName','type','sentAt','status'])
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.fromUid is string
                    && request.resource.data.type is string
                    && request.resource.data.status == 'pending';
    }

    // ── Güvenlik Olayları ────────────────────────────────────
    match /security_events/{eventId} {
      // Herhangi bir oturum açmış kullanıcı olay yazabilir (kendi olayı)
      allow create: if request.auth != null
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.type is string
                    && request.resource.data.type.size() <= 50;
      // Sadece admin okuyabilir
      allow read: if request.auth != null
                  && request.auth.token.email == 'rahman.eraydin@gmail.com';
      allow update, delete: if false;
    }

    // ── Reddet: Yukarıdaki kurallara uymayan her şey ──────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
